{
    "openapi": "3.0.0",
    "info": {
        "title": "Sandbox API",
        "description": "Authentication API documentation",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Current application host"
        }
    ],
    "paths": {
        "/api/v1/register": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Register a user",
                "operationId": "authRegister",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Maksym"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "koctenko525@gmail.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "RootRoot123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Registered",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "required": [
                                        "type",
                                        "data"
                                    ],
                                    "properties": {
                                        "type": {
                                            "type": "string",
                                            "example": "data"
                                        },
                                        "data": {
                                            "required": [
                                                "user",
                                                "access_token",
                                                "refresh_token",
                                                "token_type",
                                                "expires_in"
                                            ],
                                            "properties": {
                                                "user": {
                                                    "required": [
                                                        "id",
                                                        "name",
                                                        "email",
                                                        "profile_image"
                                                    ],
                                                    "properties": {
                                                        "id": {
                                                            "type": "integer",
                                                            "example": 6
                                                        },
                                                        "name": {
                                                            "type": "string",
                                                            "example": "Maksym"
                                                        },
                                                        "email": {
                                                            "type": "string",
                                                            "format": "email",
                                                            "example": "koctenko525@gmail.com"
                                                        },
                                                        "profile_image": {
                                                            "type": "string",
                                                            "example": "http://localhost/storage/profile_images/65f8f6f9c3_avatar.jpg",
                                                            "nullable": true
                                                        }
                                                    },
                                                    "type": "object"
                                                },
                                                "access_token": {
                                                    "type": "string",
                                                    "example": "xxx"
                                                },
                                                "refresh_token": {
                                                    "type": "string",
                                                    "example": "xxx"
                                                },
                                                "token_type": {
                                                    "type": "string",
                                                    "example": "bearer"
                                                },
                                                "expires_in": {
                                                    "type": "integer",
                                                    "example": 3600
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "required": [
                                        "type",
                                        "message",
                                        "details"
                                    ],
                                    "properties": {
                                        "type": {
                                            "type": "string",
                                            "example": "validation_error"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Email is taken"
                                        },
                                        "details": {
                                            "type": "array",
                                            "items": {
                                                "required": [
                                                    "field",
                                                    "messages"
                                                ],
                                                "properties": {
                                                    "field": {
                                                        "type": "string",
                                                        "example": "email"
                                                    },
                                                    "messages": {
                                                        "type": "array",
                                                        "items": {
                                                            "type": "string",
                                                            "example": "Email is taken"
                                                        }
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
